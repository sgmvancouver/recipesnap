{
  "schemaVersion": "1.0.0",
  "defaultLoad": [
    "rules.md",
    "manifest.json"
  ],
  "sessionLoad": [
    "session-context.md",
    "session-state.json"
  ],
  "domainRules": [
    {
      "domain": "security",
      "keywords": ["auth", "security", "password", "jwt", "stripe", "payment"],
      "loadAgents": ["security-reviewer"],
      "loadSkills": ["security-practices"]
    },
    {
      "domain": "frontend",
      "keywords": ["react", "ui", "ux", "theme", "dark mode"],
      "loadAgents": ["frontend-specialist"],
      "loadSkills": ["frontend-patterns"]
    },
    {
      "domain": "backend",
      "keywords": ["api", "node", "stripe", "webhook"],
      "loadAgents": ["backend-specialist"],
      "loadSkills": ["api-patterns", "nodejs-patterns"]
    },
    {
      "domain": "database",
      "keywords": ["database", "prisma", "schema"],
      "loadAgents": ["database-architect"],
      "loadSkills": ["database-design"]
    },
    {
      "domain": "planning",
      "keywords": ["plan", "milestone", "roadmap"],
      "loadAgents": ["planner"],
      "loadSkills": ["plan-writing", "brainstorming"]
    }
  ],
  "contextBudget": {
    "maxAgentsPerSession": 2,
    "maxSkillsPerSession": 4,
    "warningThresholdPercent": 80,
    "description": "High-Precision loading. Only 2 agents and 4 skills max per session to preserve tokens."
  },
  "workflowBindings": [
    { "workflow": "plan", "loadAgents": ["planner"], "loadSkills": ["plan-writing", "brainstorming"], "bindingType": "explicit" },
    { "workflow": "status", "loadAgents": [], "loadSkills": ["verification-loop"], "bindingType": "inferred" }
  ]
}
